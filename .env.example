# VulnHunter — Environment Configuration
# Copy this file to .env and fill in your API keys

# ═══ LLM Provider (set ONE of these) ═══
# Auto-detects provider from whichever key is set
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_API_KEY=

# ═══ Override provider/model manually (optional) ═══
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1

# ═══ Security ═══
# JWT_SECRET_KEY=generate-a-random-64-char-string-here

# ═══ Database (optional, works without it) ═══
# DATABASE_URL=postgresql+asyncpg://vulnhunter:vulnhunter@localhost:5432/vulnhunter
# Docker Compose (service name `postgres`):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@postgres:5432/vulnhunter

# ═══ Docker Compose / sandbox ═══
# Pro tools from inside the app container need the host Docker socket (default path works on Linux and Docker Desktop).
# DOCKER_SOCK=/var/run/docker.sock
# Enable sandbox when using baked config with sandbox.enabled: false (Compose sets true by default via env).
# VULNHUNTER_SANDBOX_ENABLED=true
# Optional: PentAGI-style extra capability for sandbox containers (not recommended unless needed).
# VULNHUNTER_SANDBOX_NET_ADMIN=false

# ═══ Shodan (optional) ═══
# SHODAN_API_KEY=
